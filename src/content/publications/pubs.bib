@article{Yao2021ATranscriptomicAndEpigenomic,
    title = "A transcriptomic and epigenomic cell atlas of the mouse primary motor cortex",
    author = "Zizhen Yao and Hanqing Liu and Fangming Xie and Stephan Fischer and Ricky S. Adkins and Andrew Aldridge and Seth A. Ament and Anna Bartlett and M. Margarita Behrens and Koen Van Den Berge and Darren Bertagnolli and Hector Roux de Bézieux and Tommaso Biancalani and A. Sina Booeshaghi and Héctor Corrada Bravo and Tamara Casper and Carlo Colantuoni and Jonathan Crabtree and Heather H. Creasy and Kirsten Crichton and Megan Crow and Nick Dee and Elizabeth L. Dougherty and Wayne I. Doyle and Sandrine Dudoit and Rongxin Fang and Victor Felix and Olivia Fong and Michelle Giglio and Jeff Goldy and Mike Hawrylycz and Brian R. Herb and Ronna Hertzano and Xiaomeng Hou and Qiwen Hu and Jayaram Kancherla and Matthew Kroll and Kanan Lathia and Yang Eric Li and Jacinta Lucero and Chongyuan Luo and Anup Mahurkar and Delissa McMillen and Naeem Nadaf and Joseph R. Nery and Thuc Nghi Nguyen and Sheng-Yong Niu and Vasilis Ntranos and Joshua Orvis and Julia Osteen and Thanh Pham and António Pinto‐Duarte and Olivier Poirion and Sebastian Preißl and Elizabeth Purdom and Christine Rimorin and Davide Risso and Angeline Rivkin and Kimberly A. Smith and Kelly Street and Josef Šulc and Valentine Svensson and Michael Tieu and Amy Torkelson and Herman Tung and Eeshit Dhaval Vaishnav and Charles Vanderburg and Cindy T. J. van Velthoven and Xinxin Wang and Owen White and Z. Josh Huang and Peter V. Kharchenko and Lior Pachter and John Ngai and Aviv Regev and Bosiljka Tasic and Joshua D. Welch and Jesse Gillis and Evan Z. Macosko and Bing Ren and Joseph R. Ecker and Hongkui Zeng and Eran A. Mukamel",
    year = "2021",
    journal = "Nature",
    doi = "10.1038/s41586-021-03500-8",
    url = "https://doi.org/10.1038/s41586-021-03500-8",
    abstract = "Abstract Single-cell transcriptomics can provide quantitative molecular signatures for large, unbiased samples of the diverse cell types in the brain 1–3 . With the proliferation of multi-omics datasets, a major challenge is to validate and integrate results into a biological understanding of cell-type organization. Here we generated transcriptomes and epigenomes from more than 500,000 individual cells in the mouse primary motor cortex, a structure that has an evolutionarily conserved role in locomotion. We developed computational and statistical methods to integrate multimodal data and quantitatively validate cell-type reproducibility. The resulting reference atlas—containing over 56 neuronal cell types that are highly replicable across analysis methods, sequencing technologies and modalities—is a comprehensive molecular and genomic account of the diverse neuronal and non-neuronal cell types in the mouse primary motor cortex. The atlas includes a population of excitatory neurons that resemble pyramidal cells in layer 4 in other cortical regions 4 . We further discovered thousands of concordant marker genes and gene regulatory elements for these cell types. Our results highlight the complex molecular regulation of cell types in the brain and will directly enable the design of reagents to target specific cell types in the mouse primary motor cortex for functional analysis.",
    openalex_id = "https://openalex.org/W3202498768"
}

@article{Berge2018ObservationWeightsUnlockBulk,
    title = "Observation weights unlock bulk RNA-seq tools for zero inflation and single-cell applications",
    author = "Koen Van den Berge and Fanny Perraudeau and Charlotte Soneson and Michael I. Love and Davide Risso and Jean‐Philippe Vert and Mark D. Robinson and Sandrine Dudoit and Lieven Clement",
    year = "2018",
    journal = "Genome biology",
    doi = "10.1186/s13059-018-1406-4",
    url = "https://doi.org/10.1186/s13059-018-1406-4",
    abstract = "Dropout events in single-cell RNA sequencing (scRNA-seq) cause many transcripts to go undetected and induce an excess of zero read counts, leading to power issues in differential expression (DE) analysis. This has triggered the development of bespoke scRNA-seq DE methods to cope with zero inflation. Recent evaluations, however, have shown that dedicated scRNA-seq tools provide no advantage compared to traditional bulk RNA-seq tools. We introduce a weighting strategy, based on a zero-inflated negative binomial model, that identifies excess zero counts and generates gene- and cell-specific weights to unlock bulk RNA-seq DE pipelines for zero-inflated data, boosting performance for scRNA-seq.",
    openalex_id = "https://openalex.org/W2788908087"
}

