@article{Sottosanti2025SpatiallyRegularizedGaussianMixtures_2,
    title = "Spatially Regularized Gaussian Mixtures for Clustering Spatial Transcriptomic Data",
    author = "Andrea Sottosanti and Davide Risso and Francesco Denti",
    year = "2025",
    journal = "Journal of Classification",
    doi = "10.1007/s00357-025-09527-0",
    url = "https://doi.org/10.1007/s00357-025-09527-0",
    abstract = "Abstract Spatial transcriptomics measures the expression of thousands of genes in a tissue sample while preserving its spatial structure. This class of technologies has enabled the investigation of the spatial variation of gene expressions and their impact on specific biological processes. Identifying genes with similar expression profiles is of utmost importance, thus motivating the development of flexible methods leveraging spatial data structure to cluster genes. Here, we propose a modeling framework for clustering observations measured over numerous spatial locations via Gaussian processes. Rather than specifying their covariance kernels as a function of the spatial structure, we use it to inform a generalized Cholesky decomposition of their precision matrices. This approach prevents issues with kernel misspecification and facilitates the estimation of a non-stationarity spatial covariance structure. Applied to spatial transcriptomic data, our model identifies gene clusters with distinctive spatial correlation patterns across tissue areas comprising different cell types, like tumoral and stromal areas.",
    openalex_id = "https://openalex.org/W4417074676"
}

