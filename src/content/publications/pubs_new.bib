@misc{ScholarOnly003,
  title={Pan-cancer immune and stromal deconvolution predicts clinical outcomes and mutation profiles},
  author={Bhavneet Bhinder and Verena Friedl and Sunantha Sethuraman and Davide Risso and Kami E. Chiotti and R. Jay Mashl and Kyle P. Ellrott and Jordan A. Lee and Christopher K. Wong and Kofi Gyan and Aditya Deshpande and Marcin Imielinski and Rohan Bareja and Josh Stuart and Myron Peto and Katherine A. Hoadley and Alexander J. Lazar and Andrew D. Cherniack and Jingchun Zhu and Shaolong Cao and Mark Rubin and Wenyi Wang and Oliver F. Bathe and Nicolas Robine and Li Ding and Peter W. Laird and Wanding Zhou and Hui Shen and Vésteinn Thorsson and Jen Jen Yeh and Matthew H. Bailey and Daniel Cui Zhou and Xianlu L. Peng and Mary Goldman and Yongsheng Li and Anil Korkut and Nidhi Sahni and D. Neil Hayes and Michael K. A. Mensah and Ina Felau and Anab Kemal and Samantha Caesar-Johnson and John A. Demchok and Liming Yang and Martin L. Ferguson and Roy Tarnuzzer and Zhining Wang and Jean C. Zenklusen and Adam Margolin and Alana Weinstein and Andrea Sboner and Andrew Blair and Angela Brooks and Benjamin Berman and Benjamin Raphael and Brian Craft and Dante Bortone and David Heimain and David Gibbs and David Haan and Doron Betel and Duncan McColl and Emek Demir and Faeze Brahman and Farshad Farshidfar and Gaddy Getz and Galen Gao and Gordon Robertson and Huy Dinh and Hyo Young Choi and Ilya Shmulevich and Ioannis Anastopoulous and Jasmine Yang and Jeff Damrauer and Ken Chen and Lauren Sanders and Lee Cooper and Liang-Bo Wang and Matt Reyna and Mike Noble and Mohammed El-Kebir and Molly Zhang and Nicole Yeager and Paul Little and Richard Moffitt and Sam Meier and Teresa Swatloski and Theo Knijnenburg and Thomas Matthew and Vicky Chen and Vlado Uzunangelov and Xinghua Lu and Yige Wu and Yulia Newton and Zeya Wang and Paul Spellman and Olivier Elemento},
  journal={Scientific Reports},
  volume={15},
  number={1},
  publisher={Springer Science and Business Media LLC},
  year={2025},
  doi={10.1038/s41598-025-09075-y},
  url={https://doi.org/10.1038/s41598-025-09075-y},
  abstract={Abstract Traditional gene expression deconvolution methods assess a limited number of cell types, therefore do not capture the full complexity of the tumor microenvironment (TME). Here, we integrate nine deconvolution tools to assess 79 TME cell types in 10,592 tumors across 33 different cancer types, creating the most comprehensive analysis of the TME. In total, we found 41 patterns of immune infiltration and stroma profiles, identifying heterogeneous yet unique TME portraits for each cancer and several new findings. Our findings indicate that leukocytes play a major role in distinguishing various tumor types, and that a shared immune-rich TME cluster predicts better survival in bladder cancer for luminal and basal squamous subtypes, as well as in melanoma for RAS-hotspot subtypes. Our detailed deconvolution and mutational correlation analyses uncover 35 therapeutic target and candidate response biomarkers hypotheses (including CASP8 and RAS pathway genes).},
}

