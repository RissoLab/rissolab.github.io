@article{Calgaro2022BenchdamicBenchmarkingOfDifferential,
    title = {benchdamic: benchmarking of differential abundance methods for microbiome data},
    author = "Matteo Calgaro and Chiara Romualdi and Davide Risso and Nicola Vitulo",
