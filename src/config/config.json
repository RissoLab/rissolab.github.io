{
  "site": {
    "title": "RissoLab",
    "base_url": "https://nextplate.netlify.app",
    "base_path": "/",
    "trailing_slash": false,
    "favicon": "/images/favicon.png",
    "logo": "",
    "logo_darkmode": "",
    "logo_width": "150",
    "logo_height": "27",
    "logo_text": ""
  },

  "settings": {
    "search": true,
    "searchable_folders": ["news-events", "people", "publications"],
    "sticky_header": true,
    "theme_switcher": true,
    "default_theme": "dark",
    "pagination": 2,
    "summary_length": 200,
    "blog_folder": "news-events"
  },

  "announcement": {
    "enable": false,
    "content": "<span class='text-center block'>♥️ Loving Nextplate? <a class='underline' href='https://github.com/zeon-studio/nextplate' target='_blank' rel='noopener'>Please ⭐️ on Github</a></span>",
    "expire_days": 7
  },

  "params": {
    "contact_form_action": "#",
    "copyright": ""
  },

  "navigation_button": {
    "enable": true,
    "label": "Github",
    "link": "https://github.com/zeon-studio/nextplate"
  },

  "google_tag_manager": {
    "enable": false,
    "gtm_id": "GTM-XXXXXX"
  },

  "disqus": {
    "enable": false,
    "shortname": "themefisher-template",
    "settings": {}
  },

  "metadata": {
    "meta_author": "Themefisher",
    "meta_image": "/images/og-image.png",
    "meta_description": "Next Boilerplate"
  },

  "llms": {
    "generate_llms_txt": true,
    "generate_llms_full_txt": false,
    "generate_individual_md": false,
    "include": [],
    "exclude": []
  }
}
